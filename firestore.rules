rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Problems: anyone can read, only auth users can create, only author can update/delete
    match /problems/{problemId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.submittedById == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.submittedById == request.auth.uid;
    }

    // Comments: anyone can read, auth users can create, only author can delete
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // Replies: same as comments
    match /replies/{replyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // Votes: auth users can create/delete their own votes
    match /votes/{voteId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // Comment votes: same as votes
    match /commentVotes/{voteId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}
