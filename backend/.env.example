# Required — copy this to .env and fill in your values
# Never commit .env to Git

# Server
PORT=8080

# Database — match values in docker-compose.yml
DB_DSN=postgres://solvinghub:secret@localhost:5432/solvinghub_db?sslmode=disable

# Google OAuth — get these from console.cloud.google.com
# Authorized redirect URI must include: http://localhost:8080/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# JWT — use a strong random secret (e.g. openssl rand -base64 32)
JWT_SECRET=

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000,https://solvinghub.vercel.app
