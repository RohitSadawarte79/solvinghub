# Docker Environment Variables
# Copy this to .env and fill in your values before running docker-compose

# Database Configuration
POSTGRES_USER=solvinghub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=solvinghub_db
POSTGRES_PORT=5432

# API Configuration  
API_PORT=8080

# Google OAuth - get these from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# JWT Secret - use a strong random secret (e.g. openssl rand -base64 32)
JWT_SECRET=

# Frontend URL
FRONTEND_URL=http://localhost:3000
